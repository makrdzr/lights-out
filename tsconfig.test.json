{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["jest", "node", "vite/client"],
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "jest.setup.ts"
  ],
  "exclude": ["src/main.tsx"]
}
